{
  "name": "runreceipt",
  "version": "0.1.0",
  "description": "Local-first command receipts with captured output and verification",
  "type": "module",
  "bin": {
    "runreceipt": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "npm run build && node --test tests/*.test.mjs",
    "smoke": "npm run build && bash scripts/smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm test && npm run check && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "cli",
    "receipt",
    "verification",
    "testing",
    "local-first"
  ],
  "author": "Roger Chappel",
  "license": "MIT"
}
